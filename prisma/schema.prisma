generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float?
  createdAt   DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  text      String
  status    String   // "pending" | "approved"
  createdAt DateTime @default(now())
}

model Settings {
  id              String  @id @default(cuid())
  depositAmount   Float?
  venmoHandle     String?
  zelleEmail      String?
}

model Booking {
  id              String   @id @default(uuid())
  name            String
  email           String
  phone           String
  address         String?
  notes           String?
  selectedDate    String
  selectedSlot    String
  addOns          String[]
  photos          String[]

  status          String
  paymentStatus   String

  totalEstimate   Float?
  depositAmount   Float?

  reminderSent    Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SiteContent {
  id           String   @id @default("main")
  businessName String
  phone        String
  email        String
  venmo        String?
  zelle        String?
  city         String
  updatedAt    DateTime @updatedAt
}

model Availability {
  id        String   @id @default(cuid())
  date      String   @unique
  status    String
  slots     String[]
  updatedAt DateTime @updatedAt
}

model Pricing {
  id        String   @id @default(cuid())
  type      String   // "service" or "addon"
  name      String
  price     Float
  order     Int
  updatedAt DateTime @updatedAt
}

model GalleryItem {
  id        String   @id @default(cuid())
  imageUrl  String
  category  String
  type      String
  position  Int
  createdAt DateTime @default(now())
}

model Quote {
  id           String   @id @default(cuid())
  name         String
  email        String
  cleaningType String?
  bedrooms     String?
  bathrooms    String?
  sqft         String?
  condition    String?
  message      String?
  status       String
  estimate     Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TikTokVideo {
  id        String   @id @default(cuid())
  url       String
  position  Int
  createdAt DateTime @default(now())
}

model ServiceItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float?
  position    Int
  createdAt   DateTime @default(now())
}