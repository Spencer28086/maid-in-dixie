generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float?
  createdAt   DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  content   String
  rating    Int
  createdAt DateTime @default(now())
}

model GalleryItem {
  id         String   @id @default(cuid())
  beforeUrl  String
  afterUrl   String
  createdAt  DateTime @default(now())
}

model Settings {
  id              String  @id @default(cuid())
  depositAmount   Float?
  venmoHandle     String?
  zelleEmail      String?
}

model Booking {
  id              String   @id @default(uuid())
  name            String
  email           String
  phone           String
  address         String?
  notes           String?
  selectedDate    String
  selectedSlot    String
  addOns          String[]
  photos          String[]

  status          String
  paymentStatus   String

  totalEstimate   Float?
  depositAmount   Float?

  reminderSent    Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}