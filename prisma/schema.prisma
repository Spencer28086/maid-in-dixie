generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float?
  createdAt   DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  content   String
  rating    Int
  createdAt DateTime @default(now())
}

model GalleryItem {
  id         String   @id @default(cuid())
  beforeUrl  String
  afterUrl   String
  createdAt  DateTime @default(now())
}

model Settings {
  id              String  @id @default(cuid())
  depositAmount   Float?
  venmoHandle     String?
  zelleEmail      String?
}